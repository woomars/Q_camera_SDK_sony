<Window x:Class="CameraDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="13MP Camera SDK Demo" Height="720" Width="1280" Background="#1E1E1E">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <!-- Preview Area -->
        <Border Grid.Column="0" Grid.Row="0" BorderBrush="#333" BorderThickness="1" Background="Black">
            <Image x:Name="PreviewImage" Stretch="Uniform" />
        </Border>

        <!-- Sidebar Controls -->
        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Margin="10,0,0,0">
            <TextBlock Text="Camera Controls" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <TextBlock Text="Exposure (us):" Foreground="#AAA" Margin="0,5,0,2"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="ExposureSlider" Minimum="1" Maximum="100000" Value="1000" Width="220" TickFrequency="100" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                <TextBlock x:Name="ExposureValue" Text="1000" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Gain:" Foreground="#AAA" Margin="0,15,0,2"/>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="GainSlider" Minimum="0" Maximum="255" Value="0" Width="220" VerticalAlignment="Center"/>
                <TextBlock x:Name="GainValue" Text="0" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Trigger Mode:" Foreground="#AAA" Margin="0,15,0,2"/>
            <ComboBox x:Name="TriggerModeCombo" SelectedIndex="0" Margin="0,5,0,0" Background="#333" Foreground="White">
                <ComboBoxItem Content="Continuous"/>
                <ComboBoxItem Content="Software Trigger"/>
                <ComboBoxItem Content="Hardware Trigger"/>
            </ComboBox>

            <Button x:Name="SoftwareTriggerBtn" Content="Trigger Capture" Margin="0,20,0,0" Height="40" Background="#007ACC" Foreground="White" IsEnabled="False"/>

            <Button x:Name="StartStopBtn" Content="Start Capture" Margin="0,30,0,0" Height="50" Background="#28A745" Foreground="White" FontSize="16" FontWeight="Bold"/>

            <Separator Margin="0,20,0,20" Background="#333"/>
            
            <Button x:Name="SaveBtn" Content="Save Last Image" Height="40" Background="#6C757D" Foreground="White"/>
        </StackPanel>

        <!-- Log Window -->
        <Border Grid.Column="0" Grid.Row="1" Margin="0,10,0,0" BorderBrush="#333" BorderThickness="1" Background="#121212">
            <ScrollViewer x:Name="LogScroll">
                <TextBlock x:Name="LogText" Foreground="#00FF00" FontFamily="Consolas" Margin="5" TextWrapping="Wrap" Text="Welcome to Camera SDK Demo..."/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
